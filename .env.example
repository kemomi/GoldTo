# ═══════════════════════════════════════════════════════════
#  GoldTo 环境变量配置
#  cp .env.example .env
#  不填写 LLM_API_KEY 将自动启用 Mock 模式（完整功能体验）
# ═══════════════════════════════════════════════════════════

# ── LLM API（支持任何 OpenAI 兼容接口）─────────────────────
# 推荐：阿里百炼 qwen-plus → https://bailian.console.aliyun.com/
# 也支持：OpenAI / DeepSeek / Moonshot / Groq 等
# 【留空则自动进入 Mock 模式，无需 API Key 即可完整体验】
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ── Zep Cloud 长期记忆（可选）──────────────────────────────
# 免费额度：https://app.getzep.com/
# 未填写时自动使用内存模式
ZEP_API_KEY=

# ── 仿真参数默认值 ──────────────────────────────────────────
SIMULATION_ROUNDS=30
AGENTS_COUNT=12
MAX_TOKENS=2000
